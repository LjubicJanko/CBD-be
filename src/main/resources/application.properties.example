# Template for environment-specific config. Copy to one of:
#   - application-local.properties     (for local dev, gitignored)
#   - application-staging.properties   (for staging, gitignored)
# ...and fill in real values. Activate the profile when running:
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=local
# Or set these as environment variables instead — the base application.properties
# reads them via ${VAR_NAME}.

# --- Database ---
# Example for local dev (adjust to your local MySQL):
#   spring.datasource.url=jdbc:mysql://localhost:3306/cbd?serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
#   spring.datasource.username=root
#   spring.datasource.password=YOUR_LOCAL_MYSQL_PASSWORD
#
# Example for staging/prod against Railway:
#   spring.datasource.url=jdbc:mysql://<RAILWAY_HOST>:<RAILWAY_PORT>/railway?serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
#   spring.datasource.username=root
#   spring.datasource.password=<RAILWAY_PASSWORD>
spring.datasource.url=
spring.datasource.username=
spring.datasource.password=

# --- JWT signing key ---
# 64-char hex string (256 bits of entropy). Generate with:
#   openssl rand -hex 32
# Rotating this value invalidates every issued token — coordinate as a logout-for-all event.
security.jwt.secret-key=
